---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '吴瑾楠 | 新媒体运营',
  description = '澳⻔科技大学新闻传播专业，求职新媒体运营',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
<script is:global>
  // 3D carousel positioning
  const TOTAL = 8;
  const VISIBLE = 5;
  const GAP = 40;
  const SKEW = 22;
  const slideW = 300;

  function getSlideStyle(index, current) {
    const offset = ((index - current) % TOTAL + TOTAL) % TOTAL;
    const translateZ = Math.max(0, VISIBLE - offset) * 30;
    const tx = offset === 0 ? 0 : offset * (slideW / 2 + GAP / 2) * (offset <= VISIBLE / 2 ? 1 : -1) * 0.7;
    const scale = Math.pow(0.92, offset);
    const opacity = offset === 0 ? 1 : offset < VISIBLE ? 0.6 : 0;
    return { translateZ, tx, scale, opacity };
  }

  function positionSlides(current) {
    const slides = document.querySelectorAll('.carousel-slide');
    slides.forEach((slide, i) => {
      const { translateZ, tx, scale, opacity } = getSlideStyle(i, current);
      slide.style.transform = `translateX(-50%) translateZ(-${translateZ}px) translateX(${tx}px) scale(${scale})`;
      slide.style.opacity = opacity;
      slide.style.zIndex = TOTAL - Math.abs(((i - current) % TOTAL + TOTAL) % TOTAL);
      slide.style.filter = offset => offset !== 0 ? 'blur(1px)' : 'none';
    });
    const dots = document.querySelectorAll('.carousel-dot');
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === current);
    });
  }

  function rotateCarousel(dir) {
    const current = parseInt(sessionStorage.getItem('photoIndex') || '0');
    const next = (current + dir + TOTAL) % TOTAL;
    sessionStorage.setItem('photoIndex', next);
    const track = document.getElementById('photoCarousel');
    const rotY = -next * (360 / TOTAL);
    track.style.transform = `rotateY(${rotY}deg)`;
    positionSlides(next);
  }

  function initCarousel() {
    const saved = parseInt(sessionStorage.getItem('photoIndex') || '0');
    const track = document.getElementById('photoCarousel');
    if (track) {
      track.style.transform = `rotateY(${-saved * (360 / TOTAL)}deg)`;
      positionSlides(saved);
      const dotsContainer = document.getElementById('carouselDots');
      if (dotsContainer) {
        dotsContainer.innerHTML = '';
        for (let i = 0; i < TOTAL; i++) {
          const dot = document.createElement('div');
          dot.className = `carousel-dot${i === saved ? ' active' : ''}`;
          dot.onclick = () => goToSlide(i);
          dotsContainer.appendChild(dot);
        }
      }
    }
  }

  function goToSlide(index) {
    const current = parseInt(sessionStorage.getItem('photoIndex') || '0');
    const diff = ((index - current) % TOTAL + TOTAL) % TOTAL;
    if (diff <= TOTAL / 2) {
      for (let i = 0; i < diff; i++) rotateCarousel(1);
    } else {
      for (let i = 0; i < TOTAL - diff; i++) rotateCarousel(-1);
    }
  }

  window.rotateCarousel = rotateCarousel;
  window.goToSlide = goToSlide;
  window.addEventListener('DOMContentLoaded', initCarousel);
</script>
