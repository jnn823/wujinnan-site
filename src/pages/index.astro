              <div class="gallery-slide">
                <img src="/photos/photo5.jpg" alt="摄影作品 5" />
                <div class="gallery-overlay"><span>Photo 05</span></div>
              </div>
              <div class="gallery-slide">
                <img src="/photos/photo6.jpg" alt="摄影作品 6" />
                <div class="gallery-overlay"><span>Photo 06</span></div>
              </div>
              <div class="gallery-slide">
                <img src="/photos/photo7.jpg" alt="摄影作品 7" />
