---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- 导航 -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-8 py-4 flex items-center justify-between">
      <a href="#" class="text-sm font-medium tracking-tight text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors">Einan</a>
      <div class="flex gap-8 text-sm text-[var(--color-text-secondary)]">
        <a href="#about" class="hover:text-[var(--color-text-primary)] transition-colors">关于</a>
        <a href="#resume" class="hover:text-[var(--color-text-primary)] transition-colors">简历</a>
        <a href="#portfolio" class="hover:text-[var(--color-text-primary)] transition-colors">作品集</a>
        <a href="#contact" class="hover:text-[var(--color-text-primary)] transition-colors">联系</a>
      </div>
    </div>
  </nav>

  <main class="pt-16">
    <!-- Hero -->
    <section id="hero" class="min-h-[85vh] flex flex-col items-center justify-center px-8">
      <!-- 头像占位 -->
      <div class="w-28 h-28 rounded-full border-2 border-[var(--color-border)] flex items-center justify-center mb-6 overflow-hidden bg-[var(--color-border)]/30">
        <img src="/avatar.png" class="w-full h-full object-cover" style="object-position: center 25%;" />
      </div>

      <!-- 名字 -->
      <h1 class="text-4xl md:text-5xl font-medium tracking-tight text-[var(--color-text-primary)] mb-6">
        吴瑾楠 <span class="text-[var(--color-text-muted)] font-light">Einan</span>
      </h1>

      <!-- 中间描述卡片 -->
      <div class="hero-search-box px-6 md:px-10 py-3 mb-8 text-center w-full max-w-2xl mx-auto">
        <p class="hero-search-text text-center">
          澳门科技大学新闻传播专业，具备内容策划、视频剪辑、平面设计、AI创作等新媒体全链路能力
        </p>
      </div>

      <!-- 两个按钮 -->
      <div class="flex gap-4">
        <a href="#portfolio" class="inline-flex items-center gap-2 px-7 py-3 bg-[var(--color-accent)] text-white text-sm font-medium rounded-sm hover:bg-[#c07589] transition-colors">
          查看作品集
        </a>
        <a href="#contact" class="inline-flex items-center gap-2 px-7 py-3 border border-[var(--color-accent)] text-[var(--color-accent)] text-sm font-medium rounded-sm hover:bg-[var(--color-accent)] hover:text-white transition-colors">
          联系我
        </a>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-8">
      <div class="h-px bg-[var(--color-border)]"></div>
    </div>

    <!-- 关于 -->
    <section id="about" class="py-24">
      <div class="max-w-4xl mx-auto px-8">
        <p class="section-label mb-2">About</p>
        <h2 class="section-title mb-10">关于我</h2>
        <!-- 快速介绍 + 数字统计 -->
        <div class="grid md:grid-cols-3 gap-4 mb-8">
          <div class="card p-5 text-center border-2 border-[var(--color-accent-light)]">
            <p class="text-3xl font-bold text-[var(--color-accent)] mb-1">3</p>
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">段实习经历</p>
          </div>
          <div class="card p-5 text-center border-2 border-[var(--color-accent-light)]">
            <p class="text-3xl font-bold text-[var(--color-accent)] mb-1">6</p>
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">项核心技能</p>
          </div>
          <div class="card p-5 text-center border-2 border-[var(--color-accent-light)]">
            <p class="text-3xl font-bold text-[var(--color-accent)] mb-1">2026</p>
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">届毕业生</p>
          </div>
        </div>
        <!-- 一句话介绍 -->
        <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8 text-sm">
          沉稳真诚，适应力强。网感敏锐，精准捕捉热点与受众喜好；创意驱动，内容赋能品牌传播。
        </p>
        <!-- 教育背景 + 语言 -->
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <div class="card p-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-[var(--color-accent-light)] flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-[var(--color-text-primary)]">澳门科技大学</p>
                  <p class="text-xs text-[var(--color-text-muted)]">新闻传播 · 2022.09 – 2026.06</p>
                </div>
              </div>
            </div>
            <div class="card p-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-[var(--color-accent-light)] flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-[var(--color-text-primary)]">香港浸会大学</p>
                  <p class="text-xs text-[var(--color-text-muted)]">人工智能与数字媒体 · 2026.09 – 2027.06 <span class="tag ml-1">已录取</span></p>
                </div>
              </div>
            </div>
          </div>
          <div class="space-y-4">
            <div>
              <p class="text-xs font-medium tracking-widest uppercase text-[var(--color-text-muted)] mb-3">语言能力</p>
              <div class="flex gap-6">
                <div class="card p-3 flex-1 text-center">
                  <p class="text-lg font-bold text-[var(--color-text-primary)]">6.5</p>
                  <p class="text-xs text-[var(--color-text-muted)]">雅思</p>
                </div>
                <div class="card p-3 flex-1 text-center">
                  <p class="text-lg font-bold text-[var(--color-text-primary)]">CET-6</p>
                  <p class="text-xs text-[var(--color-text-muted)]">英语六级</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-8">
      <div class="h-px bg-[var(--color-border)]"></div>
    </div>

    <!-- 简历 -->
    <section id="resume" class="py-24">
      <div class="max-w-4xl mx-auto px-8">
        <p class="section-label mb-2">Resume</p>
        <h2 class="section-title mb-10">工作经历</h2>

        <div class="space-y-10">
          <!-- 实习经历 -->
          <div>
            <p class="text-xs font-medium tracking-widest uppercase text-[var(--color-text-muted)] mb-6">实习经历</p>
            <div class="space-y-8">
              <!-- 山海星辰文化传媒 -->
              <div class="grid md:grid-cols-[180px_1fr] gap-4">
                <div>
                  <p class="text-xs text-[var(--color-text-muted)]">2025.06 – 2025.08</p>
                  <p class="text-xs font-medium text-[var(--color-highlight)] mt-1">新媒体运营</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-0.5">山海星辰文化传媒公司</p>
                </div>
                <div class="space-y-2">
                  <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>运营小红书、抖音、微博、红果等多平台，制定并执行品牌传播策略，建立一致的品牌形象</span>
                    </li>
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>增加短剧宣传内容种类（花絮、采访等），提升抖音发布频率，超过10部视频浏览量超过1万次</span>
                    </li>
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>在主流社媒平台进行舆情维护，监测负面评论并及时处理，创作14条雇主品牌帖子维护品牌声誉</span>
                    </li>
                  </ul>
                </div>
              </div>

              <!-- 东信时代 -->
              <div class="grid md:grid-cols-[180px_1fr] gap-4">
                <div>
                  <p class="text-xs text-[var(--color-text-muted)]">2024.06 – 2024.07</p>
                  <p class="text-xs font-medium text-[var(--color-highlight)] mt-1">视频剪辑实习生</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-0.5">东信时代信息技术公司</p>
                </div>
                <div class="space-y-2">
                  <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>针对小说平台推广需求，分析各平台用户画像与喜好，创作并剪辑推广视频，有效吸引用户下载注册小说平台</span>
                    </li>
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>结合小说情节、热门元素，提出剧情反转式、互动式推广视频等创意，提升视频趣味性与传播力</span>
                    </li>
                  </ul>
                </div>
              </div>

              <!-- 星辰海医疗 -->
              <div class="grid md:grid-cols-[180px_1fr] gap-4">
                <div>
                  <p class="text-xs text-[var(--color-text-muted)]">2023.06 – 2023.08</p>
                  <p class="text-xs font-medium text-[var(--color-highlight)] mt-1">市场部运营实习生</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-0.5">星辰海医疗公司</p>
                </div>
                <div class="space-y-2">
                  <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>负责公司微信公众号的内容策划、编写及排版工作，结合医疗行业动态与公司业务重点，撰写多篇优质文章</span>
                    </li>
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>依据公众号定位与目标受众，制定并执行推广策略，有效提升公司品牌在新媒体平台的知名度与影响力</span>
                    </li>
                    <li class="flex gap-2">
                      <span class="text-[var(--color-highlight)] mt-1.5 flex-shrink-0">
                        <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
                      </span>
                      <span>协助完成线上活动策划与执行，为公司产品推广与业务拓展提供有力支持</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- 校园经历 -->
          <div>
            <p class="section-label mb-2">Campus</p>
            <h2 class="section-title mb-6">校园经历</h2>
            <div class="grid md:grid-cols-3 gap-4">
              <div class="card p-4 space-y-1">
                <p class="text-sm font-medium text-[var(--color-text-primary)]">校舞蹈队宣传干事</p>
                <p class="text-xs text-[var(--color-text-muted)]">负责宣传物料设计与社群运营</p>
              </div>
              <div class="card p-4 space-y-1">
                <p class="text-sm font-medium text-[var(--color-text-primary)]">品牌广告营销项目</p>
                <p class="text-xs text-[var(--color-text-muted)]">整合营销方案策划与执行</p>
              </div>
              <div class="card p-4 space-y-1">
                <p class="text-sm font-medium text-[var(--color-text-primary)]">CSR公关短片拍摄</p>
                <p class="text-xs text-[var(--color-text-muted)]">微电影创作项目</p>
              </div>
            </div>
          </div>

          <!-- 技能 -->
          <div>
            <p class="section-label mb-2">Skills</p>
            <h2 class="section-title mb-6">技能特长</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              <div class="card p-4">
                <p class="text-xs font-medium text-[var(--color-text-primary)] mb-1">内容策划</p>
                <p class="text-xs text-[var(--color-text-muted)]">公众号运营方案撰写 · 小红书/抖音内容策划</p>
              </div>
              <div class="card p-4">
                <p class="text-xs font-medium text-[var(--color-text-primary)] mb-1">视频剪辑</p>
                <p class="text-xs text-[var(--color-text-muted)]">剪映 · PR，营销视频/短剧宣传制作</p>
              </div>
              <div class="card p-4">
                <p class="text-xs font-medium text-[var(--color-text-primary)] mb-1">平面设计</p>
                <p class="text-xs text-[var(--color-text-muted)]">Figma · PS，APP界面设计</p>
              </div>
              <div class="card p-4">
                <p class="text-xs font-medium text-[var(--color-text-primary)] mb-1">PPT制作</p>
                <p class="text-xs text-[var(--color-text-muted)]">逻辑清晰、视觉美观的演示文稿</p>
              </div>
              <div class="card p-4">
                <p class="text-xs font-medium text-[var(--color-text-primary)] mb-1">摄影摄像</p>
                <p class="text-xs text-[var(--color-text-muted)]">相机拍摄 · 捕捉精彩瞬间 · 网感照片</p>
              </div>
              <div class="card p-4">
                <p class="text-xs font-medium text-[var(--color-text-primary)] mb-1">AI创作</p>
                <p class="text-xs text-[var(--color-text-muted)]">海螺AI · 即梦AI · Holopix AI · 养小龙虾</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-8">
      <div class="h-px bg-[var(--color-border)]"></div>
    </div>

    <!-- 作品集 -->
    <section id="portfolio" class="py-24">
      <div class="max-w-4xl mx-auto px-8">
        <!-- 视频作品 -->
        <div class="mb-8">
          <p class="section-label mb-2">Video Works</p>
          <h3 class="section-title">视频作品</h3>
        </div>

        <div class="space-y-4">
          <!-- 作品1 -->
          <div class="space-y-2">
            <button id="openFilmBtn" class="card w-full text-left p-6 cursor-pointer hover:border-[var(--color-text-muted)] transition-colors group">
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.574z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div class="space-y-1">
                    <h3 class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-highlight)] transition-colors">《贰拾叁》剧情微短片</h3>
                    <p class="text-xs text-[var(--color-text-muted)]">点击播放 · Bilibili</p>
                  </div>
                </div>
                <svg class="w-4 h-4 text-[var(--color-text-muted)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </div>
            </button>
          </div>

          <!-- 作品2 -->
          <div class="space-y-2">
            <button id="openMuseumBtn" class="card w-full text-left p-6 cursor-pointer hover:border-[var(--color-text-muted)] transition-colors group">
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.574z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div class="space-y-1">
                    <h3 class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-highlight)] transition-colors">博物馆互动游戏短片</h3>
                    <p class="text-xs text-[var(--color-text-muted)]">点击播放 · Bilibili</p>
                  </div>
                </div>
                <svg class="w-4 h-4 text-[var(--color-text-muted)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </div>
            </button>
          </div>

          <!-- 作品3 -->
          <div class="space-y-2">
            <button id="openVideoBtn" class="card w-full text-left p-6 cursor-pointer hover:border-[var(--color-text-muted)] transition-colors group">
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.574z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div class="space-y-1">
                    <h3 class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-highlight)] transition-colors">跨文化传播Vlog</h3>
                    <p class="text-xs text-[var(--color-text-muted)]">点击播放 · Bilibili</p>
                  </div>
                </div>
                <svg class="w-4 h-4 text-[var(--color-text-muted)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </div>
            </button>
          </div>

          <!-- 作品4 - 旅游Vlog -->
          <div class="space-y-2">
            <button id="openTravelBtn" class="card w-full text-left p-6 cursor-pointer hover:border-[var(--color-text-muted)] transition-colors group">
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center flex-shrink-0">
