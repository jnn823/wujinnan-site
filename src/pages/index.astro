              <div class="space-y-1">
                <h3 class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-highlight)] transition-colors">自制旅游Vlog</h3>
                <p class="text-xs text-[var(--color-text-muted)]">百度网盘 · 2025年自制内容</p>
              </div>
              <svg class="w-4 h-4 text-[var(--color-text-muted)] flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </div>
          </a>
        </div>
        <!-- 摄影作品 -->
        <div class="mt-12">
          <p class="section-label mb-2">Photography</p>
          <h3 class="section-title mb-8">摄影作品</h3>
          <div class="gallery-wrapper">
            <div class="gallery-track" id="galleryCarousel">
              <div class="gallery-slide">
                <img src="/photos/photo1.jpg" alt="摄影作品 1" />
                <div class="gallery-overlay"><span>Photo 01</span></div>
              </div>
              <div class="gallery-slide">
                <img src="/photos/photo2.jpg" alt="摄影作品 2" />
