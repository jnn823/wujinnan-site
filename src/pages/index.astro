  <script>
    const modal = document.getElementById('videoModal');
    const openBtn = document.getElementById('openVideoBtn');
    const closeBtn = document.getElementById('closeVideoBtn');
    const iframe = document.getElementById('videoIframe') as HTMLIFrameElement;

    const closeTravelBtn = document.getElementById('closeTravelBtn');
    const travelIframe = document.getElementById('travelIframe') as HTMLIFrameElement;

    const filmModal = document.getElementById('filmModal');
    const openFilmBtn = document.getElementById('openFilmBtn');
    const closeFilmBtn = document.getElementById('closeFilmBtn');
    const filmIframe = document.getElementById('filmIframe') as HTMLIFrameElement;

    const museumModal = document.getElementById('museumModal');
    const openMuseumBtn = document.getElementById('openMuseumBtn');
    const closeMuseumBtn = document.getElementById('closeMuseumBtn');
    const museumIframe = document.getElementById('museumIframe') as HTMLIFrameElement;

    const videoUrl = 'https://player.bilibili.com/player.html?bvid=BV1ZN5TzAEww&page=1&autoplay=1';
    const travelUrl = 'https://player.bilibili.com/player.html?bvid=BV1jMRMBHEWn&page=1&autoplay=1';
    const filmUrl = 'https://player.bilibili.com/player.html?bvid=BV1G7RMBLEtR&page=1&autoplay=1';
    const museumUrl = 'https://player.bilibili.com/player.html?bvid=BV1DxRgBmETs&page=1&autoplay=1';

    openBtn?.addEventListener('click', () => {
      if (iframe) iframe.src = videoUrl;
      modal?.classList.remove('hidden');
      setTimeout(() => modal?.classList.add('opacity-100'), 10);
    });

    openTravelBtn?.addEventListener('click', () => {
      if (travelIframe) travelIframe.src = travelUrl;
      travelModal?.classList.remove('hidden');
      setTimeout(() => travelModal?.classList.add('opacity-100'), 10);
    });

    openFilmBtn?.addEventListener('click', () => {
      if (filmIframe) filmIframe.src = filmUrl;
      filmModal?.classList.remove('hidden');
      setTimeout(() => filmModal?.classList.add('opacity-100'), 10);
    });

    openMuseumBtn?.addEventListener('click', () => {
      if (museumIframe) museumIframe.src = museumUrl;
      museumModal?.classList.remove('hidden');
      setTimeout(() => museumModal?.classList.add('opacity-100'), 10);
    });

    const closeFilmModal = () => {
      filmModal?.classList.remove('opacity-100');
      filmModal?.classList.add('opacity-0');
      setTimeout(() => {
        filmModal?.classList.add('hidden');
      }, 300);
    };

    closeFilmBtn?.addEventListener('click', closeFilmModal);
    filmModal?.addEventListener('click', (e) => {
      if (e.target === filmModal) closeFilmModal();
    });

    const closeMuseumModal = () => {
      museumModal?.classList.remove('opacity-100');
      museumModal?.classList.add('opacity-0');
      setTimeout(() => {
        museumModal?.classList.add('hidden');
      }, 300);
    };

    closeMuseumBtn?.addEventListener('click', closeMuseumModal);
    museumModal?.addEventListener('click', (e) => {
      if (e.target === museumModal) closeMuseumModal();
    });

    const closeModal = () => {
      modal?.classList.remove('opacity-100');
      modal?.classList.add('opacity-0');
      setTimeout(() => {
        modal?.classList.add('hidden');
      }, 300);
    };

    const closeTravelModal = () => {
      travelModal?.classList.remove('opacity-100');
      travelModal?.classList.add('opacity-0');
      setTimeout(() => {
        travelModal?.classList.add('hidden');
      }, 300);
    };

    closeBtn?.addEventListener('click', closeModal);
    closeTravelBtn?.addEventListener('click', closeTravelModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    travelModal?.addEventListener('click', (e) => {
      if (e.target === travelModal) closeTravelModal();
    });
  </script>
