    <div class="max-w-4xl mx-auto px-8">
      <div class="h-px bg-[var(--color-border)]"></div>
    </div>

    <!-- 联系 -->
    <section id="contact" class="py-24">
      <div class="max-w-4xl mx-auto px-8">
        <p class="section-label mb-2">Contact</p>
        <h2 class="section-title mb-8">联系我</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="mailto:2293129314@qq.com" class="card p-6 hover:border-[var(--color-text-muted)] transition-colors group">
            <p class="text-xs font-medium tracking-widest uppercase text-[var(--color-text-muted)] mb-2">邮箱</p>
            <p class="text-sm text-[var(--color-text-primary)] group-hover:text-[var(--color-highlight)] transition-colors">2293129314@qq.com</p>
          </a>
